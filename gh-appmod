#!/usr/bin/env bash
set -e

# ─── gh-appmod ───────────────────────────────────────────────────────────────
# GitHub CLI extension for GitHub Copilot App Modernization for Java.
# Helps developers upgrade, migrate, and deploy Java applications using
# GitHub Copilot CLI and the App Modernization MCP server.
# ─────────────────────────────────────────────────────────────────────────────

VERSION="0.1.0"

# MCP server configuration
MCP_SERVER_NAME="app-modernization"
MCP_SERVER_PACKAGE="@microsoft/github-copilot-app-modernization-mcp-server"

COPILOT_CONFIG_DIR="${COPILOT_HOME:-$HOME/.copilot}"
MCP_CONFIG_FILE="${COPILOT_CONFIG_DIR}/mcp-config.json"

# ─── Colors ──────────────────────────────────────────────────────────────────

if [ -t 1 ]; then
  BOLD='\033[1m'
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  NC='\033[0m'
else
  BOLD='' RED='' GREEN='' YELLOW='' BLUE='' CYAN='' NC=''
fi

# ─── Utility Functions ───────────────────────────────────────────────────────

print_header() {
  echo -e "${BOLD}${CYAN}GitHub Copilot App Modernization for Java${NC}"
  echo -e "${CYAN}──────────────────────────────────────────${NC}"
}

success() { echo -e "${GREEN}✓${NC} $1"; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }
error()   { echo -e "${RED}✗${NC} $1" >&2; }
info()    { echo -e "${BLUE}ℹ${NC} $1"; }

# ─── Prerequisite Checks ────────────────────────────────────────────────────

check_node() {
  if ! type -p node >/dev/null 2>&1; then
    error "Node.js is not installed. Version 22+ is required."
    echo "  Install from: https://nodejs.org/"
    return 1
  fi

  local node_version node_major
  node_version=$(node --version | sed 's/^v//')
  node_major=$(echo "$node_version" | cut -d. -f1)

  if [ "$node_major" -lt 22 ]; then
    error "Node.js version $node_version found, but 22+ is required."
    return 1
  fi

  success "Node.js v$node_version"
}

check_npm() {
  if ! type -p npm >/dev/null 2>&1; then
    error "npm is not installed. Version 10+ is required."
    return 1
  fi

  local npm_version npm_major
  npm_version=$(npm --version)
  npm_major=$(echo "$npm_version" | cut -d. -f1)

  if [ "$npm_major" -lt 10 ]; then
    error "npm version $npm_version found, but 10+ is required."
    return 1
  fi

  success "npm v$npm_version"
}

check_copilot() {
  if ! type -p copilot >/dev/null 2>&1; then
    error "GitHub Copilot CLI is not installed."
    echo "  Install: https://docs.github.com/en/copilot/how-tos/set-up/install-copilot-cli"
    return 1
  fi

  local copilot_version
  copilot_version=$(copilot --version 2>/dev/null | head -1)
  success "Copilot CLI $copilot_version"
}

check_gh() {
  if ! type -p gh >/dev/null 2>&1; then
    error "GitHub CLI (gh) is not installed."
    return 1
  fi
  success "GitHub CLI ($(gh --version 2>/dev/null | head -1))"
}

# Resolve the directory where this extension is installed
EXTENSION_DIR="$(cd "$(dirname "$0")" && pwd)"

# Agentic workflow source files bundled with this extension
AW_WORKFLOWS_DIR="${EXTENSION_DIR}/.github/workflows"
AW_AGENTS_DIR="${EXTENSION_DIR}/.github/agents"

# Skills source directory bundled with this extension
SKILLS_SRC_DIR="${EXTENSION_DIR}/skills"

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_check() {
  print_header
  echo ""
  echo -e "${BOLD}Checking prerequisites...${NC}"
  echo ""

  local all_ok=true
  check_gh      || all_ok=false
  check_node    || all_ok=false
  check_npm     || all_ok=false
  check_copilot || all_ok=false

  echo ""

  if [ -f "$MCP_CONFIG_FILE" ]; then
    if grep -q "$MCP_SERVER_NAME" "$MCP_CONFIG_FILE" 2>/dev/null; then
      success "MCP server '${MCP_SERVER_NAME}' is configured in ${MCP_CONFIG_FILE}"
    else
      warn "MCP server '${MCP_SERVER_NAME}' not configured. Run 'gh appmod init' to add it."
    fi
  else
    warn "No MCP config found at ${MCP_CONFIG_FILE}. Run 'gh appmod init' to create it."
  fi

  echo ""
  if [ "$all_ok" = true ]; then
    success "All prerequisites met!"
  else
    error "Some prerequisites are missing. Please install them before continuing."
    exit 1
  fi
}

cmd_init() {
  print_header
  echo ""
  echo -e "${BOLD}Step 1: Configuring App Modernization MCP server...${NC}"
  echo ""

  # Ensure config directory exists
  if [ ! -d "$COPILOT_CONFIG_DIR" ]; then
    mkdir -p "$COPILOT_CONFIG_DIR"
    info "Created config directory: ${COPILOT_CONFIG_DIR}"
  fi

  if [ -f "$MCP_CONFIG_FILE" ]; then
    # Already configured?
    if grep -q "$MCP_SERVER_NAME" "$MCP_CONFIG_FILE" 2>/dev/null; then
      success "MCP server '${MCP_SERVER_NAME}' is already configured in ${MCP_CONFIG_FILE}"
    else
      # Merge into existing config using Node.js for safe JSON manipulation
      if ! type -p node >/dev/null 2>&1; then
        error "Node.js is required to safely merge JSON config. Install Node.js 22+ first."
        exit 1
      fi

      local new_config
      new_config=$(node -e "
        const fs = require('fs');
        const config = JSON.parse(fs.readFileSync(process.argv[1], 'utf8'));
        if (!config.mcpServers) config.mcpServers = {};
        config.mcpServers['${MCP_SERVER_NAME}'] = {
          type: 'local',
          command: 'npx',
          tools: ['*'],
          args: ['-y', '${MCP_SERVER_PACKAGE}']
        };
        console.log(JSON.stringify(config, null, 2));
      " "$MCP_CONFIG_FILE")
      echo "$new_config" > "$MCP_CONFIG_FILE"
      success "Added '${MCP_SERVER_NAME}' MCP server to ${MCP_CONFIG_FILE}"
    fi
  else
    # Create new config file
    cat > "$MCP_CONFIG_FILE" <<-MCPEOF
{
  "mcpServers": {
    "${MCP_SERVER_NAME}": {
      "type": "local",
      "command": "npx",
      "tools": [
        "*"
      ],
      "args": [
        "-y",
        "${MCP_SERVER_PACKAGE}"
      ]
    }
  }
}
MCPEOF
    success "Created ${MCP_CONFIG_FILE} with '${MCP_SERVER_NAME}' MCP server"
  fi

  echo ""

  # Step 2: Add custom Copilot agent to the repository (if in a git repo)
  echo -e "${BOLD}Step 2: Adding custom Copilot agent...${NC}"
  echo ""

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    info "Not inside a Git repository — skipping agent setup."
    echo ""
    info "Run 'gh appmod init' from a Git repo to add the custom agent."
    return 0
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel)

  local agent_src="${AW_AGENTS_DIR}/appmod.agent.md"
  local target_agents_dir="${repo_root}/.github/agents"
  local agent_dst="${target_agents_dir}/appmod.agent.md"

  if [ ! -f "$agent_src" ]; then
    warn "Agent file not found in extension. Skipping."
    return 0
  fi

  if [ -f "$agent_dst" ]; then
    success "Custom agent already exists at .github/agents/appmod.agent.md"
  else
    mkdir -p "$target_agents_dir"
    cp "$agent_src" "$agent_dst"
    success "Added .github/agents/appmod.agent.md"
  fi

  echo ""
  info "The custom agent enables App Modernization in Copilot Chat."
  info "Commit it with: git add .github/agents/ && git commit -m 'Add app modernization agent'"
}

cmd_add_workflows() {
  for arg in "$@"; do
    if [ "$arg" = "-h" ] || [ "$arg" = "--help" ]; then
      echo "Usage: gh appmod add-workflows [options]"
      echo ""
      echo "Add GitHub Agentic Workflows for continuous app modernization"
      echo "to the current repository."
      echo ""
      echo "This command copies agentic workflow files into your repository's"
      echo ".github/workflows/ directory and optionally compiles them."
      echo ""
      echo "Options:"
      echo "  --no-compile    Skip compiling workflows with gh aw"
      echo "  -h, --help      Show this help"
      echo ""
      echo "What gets added:"
      echo "  .github/workflows/shared/mcp/app-modernization.md  (MCP server config)"
      echo "  .github/workflows/appmod-assess.md                 (weekly health check)"
      echo "  .github/workflows/appmod-upgrade.md                (upgrade via PR)"
      echo "  .github/workflows/appmod-migrate.md                (migration via PR)"
      return 0
    fi
  done

  local skip_compile=false
  for arg in "$@"; do
    if [ "$arg" = "--no-compile" ]; then
      skip_compile=true
    fi
  done

  print_header
  echo ""
  echo -e "${BOLD}Adding agentic workflows for continuous app modernization...${NC}"
  echo ""

  # Verify we're in a git repository
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "Not inside a Git repository. Run this command from your project root."
    exit 1
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel)

  # Verify workflow source files exist in the extension
  if [ ! -d "$AW_WORKFLOWS_DIR" ]; then
    error "Agentic workflow files not found in extension at: ${AW_WORKFLOWS_DIR}"
    error "The extension installation may be incomplete."
    exit 1
  fi

  # Create target directories
  local target_dir="${repo_root}/.github/workflows"
  local target_shared_dir="${target_dir}/shared/mcp"
  mkdir -p "$target_shared_dir"

  # Copy files
  local files_copied=0
  local files_skipped=0

  # Copy workflow files
  local workflow_files=(
    "shared/mcp/app-modernization.md"
    "appmod-assess.md"
    "appmod-upgrade.md"
    "appmod-migrate.md"
  )

  for wf in "${workflow_files[@]}"; do
    local src="${AW_WORKFLOWS_DIR}/${wf}"
    local dst="${target_dir}/${wf}"

    if [ ! -f "$src" ]; then
      warn "Source file not found: ${wf} (skipping)"
      continue
    fi

    if [ -f "$dst" ]; then
      warn "Already exists: .github/workflows/${wf} (skipping)"
      files_skipped=$((files_skipped + 1))
    else
      cp "$src" "$dst"
      success "Added .github/workflows/${wf}"
      files_copied=$((files_copied + 1))
    fi
  done

  echo ""

  if [ "$files_copied" -eq 0 ] && [ "$files_skipped" -gt 0 ]; then
    info "All files already exist. Nothing to do."
    echo ""
    info "To re-add, remove the existing files and run this command again."
    return 0
  fi

  if [ "$files_copied" -eq 0 ]; then
    error "No workflow files were copied."
    exit 1
  fi

  success "Copied ${files_copied} workflow file(s)"
  echo ""

  # Attempt to compile with gh aw
  if [ "$skip_compile" = true ]; then
    info "Skipping compilation (--no-compile)."
    echo ""
    info "Compile later with: gh aw compile"
  else
    if gh aw --help >/dev/null 2>&1; then
      info "Compiling workflows with gh aw..."
      echo ""
      if (cd "$repo_root" && gh aw compile); then
        success "Workflows compiled successfully"
      else
        warn "Compilation failed. You can retry with: gh aw compile"
        echo ""
        info "Make sure gh-aw is installed: gh extension install github/gh-aw"
      fi
    else
      warn "gh-aw extension not found. Skipping compilation."
      echo ""
      info "Install it with: gh extension install github/gh-aw"
      info "Then compile:    gh aw compile"
    fi
  fi

  echo ""
  echo -e "${BOLD}Next steps:${NC}"
  echo "  1. Review the workflow files in .github/workflows/"
  echo "  2. Customize triggers, schedules, and labels as needed"
  echo "  3. Commit and push:"
  echo ""
  echo "     git add .github/workflows/"
  echo "     git commit -m \"Enable continuous app modernization workflows\""
  echo "     git push"
  echo ""
  echo "  4. Trigger your first assessment:"
  echo ""
  echo "     gh workflow run appmod-assess.lock.yml"
  echo ""
  info "Learn more: https://aka.ms/ghcp-appmod"
}

cmd_add_skills() {
  for arg in "$@"; do
    if [ "$arg" = "-h" ] || [ "$arg" = "--help" ]; then
      echo "Usage: gh appmod add-skills [options]"
      echo ""
      echo "Add custom modernization skills to your repository."
      echo ""
      echo "Copies skill definitions from the extension into .github/skills/"
      echo "following the agentskills.io specification. These skills are"
      echo "automatically detected by the Modernize CLI when creating plans."
      echo ""
      echo "Options:"
      echo "  -h, --help      Show this help"
      echo ""
      echo "Skills added:"
      echo "  assess           Modernization posture assessment"
      echo "  upgrade          General Java upgrade guidance"
      echo "  migrate          Service migration to Azure"
      echo "  deploy           Deployment to Azure services"
      echo "  java-8-to-11     JDK 8 to 11 upgrade instructions"
      echo "  java-11-to-17    JDK 11 to 17 upgrade instructions"
      echo "  java-17-to-21    JDK 17 to 21 upgrade instructions"
      echo "  java-21-to-25    JDK 21 to 25 upgrade instructions"
      return 0
    fi
  done

  print_header
  echo ""
  echo -e "${BOLD}Adding modernization skills...${NC}"
  echo ""

  # Verify we're in a git repository
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    error "Not inside a Git repository. Run this command from your project root."
    exit 1
  fi

  # Verify skill source files exist in the extension
  if [ ! -d "$SKILLS_SRC_DIR" ]; then
    error "Skills directory not found in extension at: ${SKILLS_SRC_DIR}"
    error "The extension installation may be incomplete."
    exit 1
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel)
  local target_dir="${repo_root}/.github/skills"

  local skills_copied=0
  local skills_skipped=0

  for skill_src in "$SKILLS_SRC_DIR"/*/; do
    local skill_name
    skill_name=$(basename "$skill_src")
    local skill_dst="${target_dir}/${skill_name}"

    if [ -d "$skill_dst" ]; then
      warn "Skill '${skill_name}' already exists at .github/skills/${skill_name} (skipping)"
      skills_skipped=$((skills_skipped + 1))
      continue
    fi

    mkdir -p "$skill_dst"
    cp -r "$skill_src"* "$skill_dst/"
    success "Added .github/skills/${skill_name}/"
    skills_copied=$((skills_copied + 1))
  done

  echo ""

  if [ "$skills_copied" -eq 0 ] && [ "$skills_skipped" -gt 0 ]; then
    info "All skills already exist. Nothing to do."
    echo ""
    info "To re-add, remove the existing skill folders and run this command again."
    return 0
  fi

  if [ "$skills_copied" -eq 0 ]; then
    error "No skill files were copied."
    exit 1
  fi

  success "Added ${skills_copied} skill(s) to .github/skills/"
  echo ""
  echo -e "${BOLD}Next steps:${NC}"
  echo "  1. Review the skills in .github/skills/"
  echo "  2. Customize SKILL.md files for your project as needed"
  echo "  3. Commit and push:"
  echo ""
  echo "     git add .github/skills/"
  echo "     git commit -m \"Add app modernization skills\""
  echo "     git push"
  echo ""
  info "The Modernize CLI will automatically detect these skills when creating plans."
  info "Learn more: https://aka.ms/ghcp-appmod"
}

cmd_help() {
  print_header
  echo ""
  echo -e "${BOLD}Usage:${NC} gh appmod <command> [options]"
  echo ""
  echo -e "${BOLD}Setup:${NC}"
  echo "  check           Check prerequisites (Node.js, npm, Copilot CLI)"
  echo "  init            Configure MCP server and add custom Copilot agent"
  echo ""
  echo -e "${BOLD}Repository setup:${NC}"
  echo "  add-skills      Add custom modernization skills to .github/skills/"
  echo "  add-workflows   Add agentic workflows for continuous modernization"
  echo ""
  echo -e "${BOLD}Options:${NC}"
  echo "  -h, --help      Show help for a command"
  echo "  -v, --version   Show version"
  echo ""
  echo -e "${BOLD}Getting started:${NC}"
  echo "  1. gh appmod check           # Verify prerequisites"
  echo "  2. gh appmod init             # Configure MCP server + agent"
  echo "  3. gh appmod add-skills       # Add skills to your repo"
  echo "  4. modernize upgrade          # Upgrade with Modernize CLI"
  echo ""
  echo -e "${BOLD}Continuous modernization:${NC}"
  echo "  gh appmod add-workflows       # Add agentic workflows to your repo"
  echo ""
  echo -e "${BOLD}Modernize CLI:${NC}"
  echo "  For upgrade, migrate, and deploy operations, use the Modernize CLI:"
  echo "  https://learn.microsoft.com/azure/developer/github-copilot-app-modernization"
  echo ""
  echo -e "${BOLD}Learn more:${NC}"
  echo "  https://aka.ms/ghcp-appmod"
}

# ─── Main ────────────────────────────────────────────────────────────────────

case "${1:-}" in
  check)          shift; cmd_check "$@" ;;
  init)           shift; cmd_init "$@" ;;
  add-skills)     shift; cmd_add_skills "$@" ;;
  add-workflows)  shift; cmd_add_workflows "$@" ;;
  -v|--version) echo "gh-appmod $VERSION" ;;
  -h|--help|"") cmd_help ;;
  *)
    error "Unknown command: $1"
    echo ""
    cmd_help
    exit 1
    ;;
esac
